# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.js.map

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
.eggs/

# HIVE runtime data — never commit (auto-generated per BEE)
data/bee-*/
data_b/
data/vectors/
data/corestore/
data/cache/
data/identity/
data/claim_registry/
# Forager persistent state (BFS queue + visited set, written by every
# running node) and UI-set LLM overrides (runtime.env, since v0.6.4.3).
data/crawl_queue.jsonl
data/crawl_visited.jsonl
data/.runtime.env
# topic_tree.json IS committed (it's source data, not runtime)
!data/topic_tree.json

# Model cache (downloaded by sentence-transformers / HuggingFace)
.cache/

# Environment & secrets
.env
.env.local
.env.*.local
*.key
*.pem

# OS
.DS_Store
Thumbs.db

# Editor & Claude Code local config
.vscode/settings.json
.idea/
.claude/

# Logs
*.log
npm-debug.log*

# Test artifacts (dev-only)
GEMINI.md
tmp_test_history.js
packages/core/test-hypercore.cjs
packages/core/test_watch.mjs

runDocker.info