BEE_NAME=bee-games-es
BEE_PORT=8082
BEE_EMBEDDER_PORT=7702
BEE_DATA_DIR=../../data/bee-games-es
BEE_PEER=http://127.0.0.1:8080
HIVE_OBJECTIVE="Busca noticias recientes sobre videojuegos en español usando rss_fetch. Feeds a consultar: https://vandal.elespanol.com/rss/noticias.xml y https://www.3djuegos.com/rss/noticias.php y https://es.ign.com/feed.xml. Para cada feed: llama a rss_fetch, luego llama a index_fragment por cada artículo. El id debe ser un slug del título (sin espacios ni caracteres especiales). confidence 0.9 para artículos recientes."
HIVE_EXTRACT_MAX_FRAGMENTS=30
HIVE_EXTRACT_INTERVAL_MS=1800000
