# ── BEE LLM provider ─────────────────────────────────────────────────────────
# Bees no longer need an LLM for extraction (v0.6+ extraction is LLM-free) — but
# `hive` mode reuses this key for queries. A pure producer bee can leave it blank.
#
# Default: Gemini Flash Lite. Free tier covers a small VPS. Key: https://aistudio.google.com/
LLM_PROVIDER=gemini
LLM_API_KEY=AIza_your_gemini_key_here
LLM_MODEL=gemini-2.5-flash-lite

# Alternative providers (uncomment one and comment out the gemini block above)
# LLM_PROVIDER=groq    LLM_API_KEY=gsk_your_key    LLM_MODEL=llama-3.3-70b-versatile
# LLM_PROVIDER=claude  LLM_API_KEY=sk-ant-...      LLM_MODEL=claude-sonnet-4-6
# LLM_PROVIDER=openai  LLM_API_KEY=sk-...          LLM_MODEL=gpt-4o
#
# Local LLM — no cloud cost. Activate with `docker compose --profile ollama up -d`, then:
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:1.5b


# ── Queen LLM provider ───────────────────────────────────────────────────────
# The queen synthesises answers for public queries (latency matters), so use a
# fast cloud provider here. Groq free tier (console.groq.com) is recommended.
# v0.8 canonical names are QUEEN_LLM_*; the old AGGREGATOR_LLM_* still work as a
# fallback so existing .env files keep functioning.
QUEEN_LLM_PROVIDER=groq
QUEEN_LLM_API_KEY=gsk_your_queen_key_here
# QUEEN_LLM_MODEL=llama-3.3-70b-versatile


# ── Embeddings (v0.8) ─────────────────────────────────────────────────────────
# No configuration needed. Every node embeds in-process with
# intfloat/multilingual-e5-base (ONNX int8) via @huggingface/transformers, and
# the queen stores vectors in an embedded LanceDB. There is no Python embedder
# and no Qdrant container in v0.8.


# ── Ollama model (only if using LLM_PROVIDER=ollama) ──────────────────────────
# OLLAMA_MODEL=qwen2.5:1.5b               # ~950MB, safe on a 4GB VPS
# OLLAMA_MODEL=qwen2.5:3b                 # better quality — needs 6GB+ VPS


# ── Extraction tuning ─────────────────────────────────────────────────────────
# HIVE_EXTRACT_MAX_FRAGMENTS=9            # fragments per cycle (split across topics)
# HIVE_EXTRACT_INTERVAL_MS=60000          # pause between cycles (default: 1 min)
# HIVE_EXTRACT_BUDGET_MINUTES=20          # wall-clock time per cycle

# ── External connectors (third-party ForagerSources from npm) ─────────────────
# Comma-separated npm package names to load as extra connectors at boot. Each
# must already be installed in node_modules and export a ForagerSource (default/
# named export) or a registerForagers(api) hook. Built-in connectors always load.
# Plugins run with full node privileges — only list packages you trust.
# HIVE_FORAGER_PLUGINS=@acme/hive-notion,@acme/hive-confluence

# ── Personal memory (the `personal-memory` connector — PRIVATE queens only) ───
# Pick readers in the Settings UI ("What to include"). These point each reader
# at your local data. A bee using personal-memory MUST run on a private topic.
# HIVE_CLAUDE_PROJECTS_DIR=/home/you/.claude/projects   # Claude transcripts + memory/*.md
# HIVE_NOTES_DIR=/home/you/notes                        # markdown notes (Obsidian/etc.)
# HIVE_CHATGPT_EXPORT=/home/you/chatgpt/conversations.json
# HIVE_SHELL_HISTORY=/home/you/.bash_history,/home/you/.zsh_history


# ── BEE-2 domain preference ───────────────────────────────────────────────────
# BEE2_TOPIC_DOMAIN=current_events


# ── Domain for HTTPS (optional) ───────────────────────────────────────────────
# Leave empty → HTTP on bare IP  → http://your-vps-ip  (works immediately)
# Set domain  → auto-HTTPS       → https://your-domain  (needs DNS → this VPS)
# DOMAIN=hive.capybaralabs.tech
