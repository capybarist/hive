# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option A: Groq — free cloud tier, 100K tokens/day. Get key at console.groq.com
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_key_here

# Option B: Ollama — fully local, no API key, no tokens spent.
# Requires activating the ollama Docker profile:
#   docker compose --profile ollama up -d
# Then pull the model once:
#   docker exec hive-ollama ollama pull qwen2.5:3b
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://ollama:11434   # (default, set only if custom Ollama host)

# Other cloud options:
# LLM_PROVIDER=gemini  LLM_API_KEY=...   # aistudio.google.com (free tier)
# LLM_PROVIDER=claude  LLM_API_KEY=...   # console.anthropic.com
# LLM_PROVIDER=openai  LLM_API_KEY=...   # platform.openai.com

# Optional: override the model used by the LLM provider
# LLM_MODEL=llama-3.3-70b-versatile      # Groq example
# LLM_MODEL=qwen2.5:1.5b                 # Ollama — lighter model for <2GB RAM

# ── Extraction tuning ─────────────────────────────────────────────────────────
# HIVE_EXTRACT_MAX_FRAGMENTS=20
# HIVE_EXTRACT_INTERVAL_MS=300000

# ── BEE-2 domain preference ───────────────────────────────────────────────────
# BEE2_TOPIC_DOMAIN=current_events

# ── Domain for HTTPS (optional) ──────────────────────────────────────────────
# Leave empty → HTTP on bare IP  → http://your-vps-ip  (works immediately)
# Set domain  → auto-HTTPS       → https://your-domain  (needs DNS → this VPS)
# DOMAIN=hive.capybaralabs.tech
