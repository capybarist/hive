# ── BEE LLM Provider ──────────────────────────────────────────────────────────
# Used by BEEs for autonomous extraction (runs in background — latency not critical).
#
# Default: Ollama — free, fully local, no API key needed.
# The model is pulled automatically on first start.
LLM_PROVIDER=ollama
# LLM_API_KEY=                             # not needed for Ollama

# Alternative: any cloud provider (faster extraction, uses tokens)
# LLM_PROVIDER=groq    LLM_API_KEY=gsk_your_key    # console.groq.com — free 100K/day
# LLM_PROVIDER=gemini  LLM_API_KEY=...              # aistudio.google.com — free tier
# LLM_PROVIDER=claude  LLM_API_KEY=...              # console.anthropic.com
# LLM_PROVIDER=openai  LLM_API_KEY=...              # platform.openai.com

# Optional: override default model
# LLM_MODEL=qwen2.5:1.5b                  # Ollama — default, ~950MB, fits 4GB VPS
# LLM_MODEL=qwen2.5:3b                    # Ollama — better quality, needs 6GB VPS
# LLM_MODEL=llama-3.3-70b-versatile       # Groq default
# LLM_MODEL=gemini-2.5-flash-lite         # Gemini default


# ── Aggregator LLM Provider ───────────────────────────────────────────────────
# The aggregator synthesizes answers for user queries (public-facing, must be fast).
# Ollama takes ~20s per query → Vercel/clients timeout. Use a cloud provider here.
#
# REQUIRED if you expose the aggregator publicly (e.g. via capybarahome widget).
# Groq free tier (console.groq.com) is the recommended choice — <2s responses.
AGGREGATOR_LLM_PROVIDER=groq
AGGREGATOR_LLM_API_KEY=gsk_your_aggregator_key_here

# Optional: override the model used for query synthesis
# AGGREGATOR_LLM_MODEL=llama-3.3-70b-versatile


# ── Ollama model ───────────────────────────────────────────────────────────────
# Which model to pull on first start (persists in Docker volume across restarts).
# OLLAMA_MODEL=qwen2.5:1.5b               # default — ~950MB, safe on 4GB VPS
# OLLAMA_MODEL=qwen2.5:3b                 # better quality — needs 6GB+ VPS


# ── Extraction tuning ─────────────────────────────────────────────────────────
# HIVE_EXTRACT_MAX_FRAGMENTS=9            # fragments per cycle (split across topics)
# HIVE_EXTRACT_INTERVAL_MS=60000          # pause between cycles (default: 1 min)
# HIVE_EXTRACT_BUDGET_MINUTES=20          # total LLM time per cycle


# ── BEE-2 domain preference ───────────────────────────────────────────────────
# BEE2_TOPIC_DOMAIN=current_events


# ── Domain for HTTPS (optional) ───────────────────────────────────────────────
# Leave empty → HTTP on bare IP  → http://your-vps-ip  (works immediately)
# Set domain  → auto-HTTPS       → https://your-domain  (needs DNS → this VPS)
# DOMAIN=hive.capybaralabs.tech
