# ── LLM Provider ─────────────────────────────────────────────────────────────
# Groq recommended — free tier, 100K tokens/day. Get key at console.groq.com
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_key_here

# Other options:
# LLM_PROVIDER=gemini  LLM_API_KEY=...   # aistudio.google.com
# LLM_PROVIDER=claude  LLM_API_KEY=...   # console.anthropic.com
# LLM_PROVIDER=openai  LLM_API_KEY=...   # platform.openai.com

# Optional model override
# LLM_MODEL=llama-3.3-70b-versatile

# ── Extraction tuning ─────────────────────────────────────────────────────────
# HIVE_EXTRACT_MAX_FRAGMENTS=20
# HIVE_EXTRACT_INTERVAL_MS=300000

# ── BEE-2 domain preference ───────────────────────────────────────────────────
# BEE2_TOPIC_DOMAIN=current_events

# ── Aggregator public port ────────────────────────────────────────────────────
# AGGREGATOR_PORT=8090

# ── Domain for HTTPS (optional) ──────────────────────────────────────────────
# Leave empty → HTTP on bare IP  → http://your-vps-ip  (works immediately)
# Set domain  → auto-HTTPS       → https://your-domain  (needs DNS → this VPS)
# DOMAIN=hive.capybaralabs.tech
