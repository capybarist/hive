# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: gemini | claude | openai  (default: gemini)
LLM_PROVIDER=gemini

# API key for the selected provider
LLM_API_KEY=your_api_key_here

# Optional: override the default model for the selected provider
# Defaults: gemini-2.5-flash | claude-sonnet-4-6 | gpt-4o
# LLM_MODEL=gemini-2.5-flash

# ── Network ───────────────────────────────────────────────────────────────────
# HIVE_PORT=8080
# HIVE_EMBEDDER_PORT=7700
# HIVE_DATA_DIR=~/.hive
# HIVE_PEER=http://peer.example.com

# ── Extraction ────────────────────────────────────────────────────────────────
# HIVE_OBJECTIVE=Find recent papers about retrieval augmented generation
# BEE_TOPIC_DOMAIN=health
# HIVE_EXTRACT_MAX_FRAGMENTS=20
# HIVE_EXTRACT_INTERVAL_MS=300000
