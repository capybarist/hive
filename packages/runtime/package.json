{
  "name": "@capybaralabs/hive",
  "version": "0.1.1",
  "description": "HIVE — decentralized verifiable knowledge base for LLMs. Run a queen, a bee, or both, with a one-command install. Wraps the @hive monorepo as a publishable npm CLI.",
  "license": "BUSL-1.1",
  "type": "module",
  "bin": {
    "hive": "./dist/cli.js"
  },
  "files": [
