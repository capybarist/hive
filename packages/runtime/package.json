    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsx scripts/build.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@fastify/cors": "^9",
    "@fastify/static": "^7",
    "@huggingface/transformers": "^3.3.0",
    "@lancedb/lancedb": "^0.12.0",
    "apache-arrow": "^17.0.0",
    "compact-encoding": "^2.19.2",
    "corestore": "^7",
    "fast-xml-parser": "^4.3.0",
    "fastify": "^4",
    "hyperbee": "^2",
    "hypercore": "^11",
    "hyperswarm": "^4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/capybarist/hive",
